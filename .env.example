# Base URL for mempool.space (or a self-hosted mirror). No trailing slash.
MEMPOOL_BASE_URL=https://mempool.space/api

# Bitcoin network: mainnet | testnet | signet | regtest.
NETWORK=mainnet

# Mempool fee response cache TTL in seconds (short to avoid rate limits).
MEMPOOL_CACHE_TTL=60

# Max upload size for PSBT bytes (raw/base64), in bytes.
MAX_PSBT_BYTES=1048576
